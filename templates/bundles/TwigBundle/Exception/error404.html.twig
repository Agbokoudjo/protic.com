{#
  templates/bundles/TwigBundle/Exception/error404.html.twig
  ProTIC Editions & Services — Page 404 personnalisée
#}
{% extends 'base.html.twig' %}

{% block title %}Page introuvable (404) — {{ NAME_SITE }} {% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .pe-err {
            min-height: calc(100vh - 124px);
            background: linear-gradient(155deg, #06122e 0%, #0d1f4e 45%, #0a2260 70%, #152d6e 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
            padding: 4rem 1.5rem;
        }
        .pe-err__glow {
            position: absolute;
            width: 540px; height: 540px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(45,91,227,0.16) 0%, transparent 70%);
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            pointer-events: none; z-index: 0;
        }
        .pe-err__dots {
            position: absolute;
            width: 120px; height: 120px;
            opacity: 0.13;
            background-image: radial-gradient(circle, rgba(255,255,255,0.6) 1px, transparent 1px);
            background-size: 14px 14px;
            pointer-events: none;
            top: 8%; right: 5%;
        }
        .pe-err__dots--bl { top: auto; bottom: 10%; right: auto; left: 5%; }
        .pe-err__inner {
            position: relative; z-index: 1;
            max-width: 620px; width: 100%;
            text-align: center;
        }
        .pe-err__icon {
            display: inline-flex;
            align-items: center; justify-content: center;
            width: 78px; height: 78px;
            border-radius: 50%;
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(255,255,255,0.20);
            margin: 0 auto 1.5rem;
            backdrop-filter: blur(10px);
        }
        .pe-err__icon svg { width: 36px; height: 36px; stroke: #4d8ef7; }
        .pe-err__badge {
            display: inline-flex;
            align-items: center; gap: 6px;
            padding: 4px 14px; border-radius: 999px;
            background: rgba(77,142,247,0.10);
            border: 1px solid rgba(77,142,247,0.28);
            color: rgba(168,196,255,0.80);
            font-size: 0.72rem; font-weight: 600;
            letter-spacing: 0.08em; text-transform: uppercase;
            margin-bottom: 1.5rem;
        }
        .pe-err__badge::before {
            content: ''; width: 6px; height: 6px;
            border-radius: 50%; background: #4d8ef7; display: inline-block;
        }
        .pe-err__code {
            font-size: clamp(7rem, 22vw, 13rem);
            font-weight: 800; line-height: 1;
            letter-spacing: -0.04em;
            background: linear-gradient(135deg, #a8c4ff 0%, #4d8ef7 40%, #2d5be3 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            user-select: none;
            filter: drop-shadow(0 0 40px rgba(45,91,227,0.38));
        }
        .pe-err__divider {
            width: 56px; height: 3px;
            background: linear-gradient(90deg, #2d5be3, #4d8ef7);
            border-radius: 3px;
            margin: 1rem auto 1.75rem;
        }
        .pe-err__title {
            font-size: clamp(1.35rem, 4vw, 1.9rem);
            font-weight: 700; color: #ffffff;
            margin-bottom: 1rem; line-height: 1.25;
        }
        .pe-err__desc {
            font-size: 1.05rem;
            color: rgba(255,255,255,0.68);
            line-height: 1.7; margin-bottom: 2.5rem;
            max-width: 460px;
            margin-left: auto; margin-right: auto;
        }
        .pe-err__desc strong { color: rgba(255,255,255,0.90); font-weight: 600; }
        .pe-err__btn {
            display: inline-flex;
            align-items: center; gap: 10px;
            padding: 13px 30px; border-radius: 10px;
            background: linear-gradient(135deg, #2d5be3 0%, #1a3a8f 100%);
            color: #ffffff;
            font-size: 0.92rem; font-weight: 600;
            text-decoration: none; letter-spacing: 0.02em;
            transition: transform 0.22s ease, box-shadow 0.22s ease;
            box-shadow: 0 4px 22px rgba(45,91,227,0.35);
        }
        .pe-err__btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 32px rgba(45,91,227,0.52);
            color: #ffffff;
        }
        .pe-err__btn:active { transform: translateY(0); }
        .pe-err__btn svg {
            width: 17px; height: 17px; stroke: currentColor;
            transition: transform 0.20s ease; flex-shrink: 0;
        }
        .pe-err__btn:hover svg { transform: translateX(-3px); }
        .pe-err__alt {
            display: block; margin-top: 1.2rem;
            font-size: 0.85rem;
            color: rgba(255,255,255,0.38);
            text-decoration: none;
            transition: color 0.2s;
        }
        .pe-err__alt:hover { color: rgba(255,255,255,0.68); }
        @keyframes peUp {
            from { opacity: 0; transform: translateY(18px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .pe-err__inner > * { animation: peUp 0.55s ease both; }
        .pe-err__inner > *:nth-child(1) { animation-delay: 0.05s; }
        .pe-err__inner > *:nth-child(2) { animation-delay: 0.12s; }
        .pe-err__inner > *:nth-child(3) { animation-delay: 0.19s; }
        .pe-err__inner > *:nth-child(4) { animation-delay: 0.25s; }
        .pe-err__inner > *:nth-child(5) { animation-delay: 0.31s; }
        .pe-err__inner > *:nth-child(6) { animation-delay: 0.37s; }
        .pe-err__inner > *:nth-child(7) { animation-delay: 0.43s; }
        @media (max-width: 480px) {
            .pe-err { padding: 3rem 1rem; }
            .pe-err__btn { width: 100%; justify-content: center; }
        }
    </style>
{% endblock %}
 {% block header %}{% endblock %}
 {% block nav %}{% endblock %}
 {% block script_aos %} {% endblock %}
{% block body %}
<main class="pe-err" role="main" aria-labelledby="pe-err-title">

    <div class="pe-err__glow" aria-hidden="true"></div>
    <div class="pe-err__dots" aria-hidden="true"></div>
    <div class="pe-err__dots pe-err__dots--bl" aria-hidden="true"></div>

    <div class="pe-err__inner">

        <div class="pe-err__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5"
                 stroke-linecap="round" stroke-linejoin="round">
                <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
            </svg>
        </div>

        <p class="pe-err__badge">Erreur {{ status_code ?? 404 }}</p>

        <div class="pe-err__code" aria-hidden="true">404</div>

        <div class="pe-err__divider"></div>

        <h1 class="pe-err__title" id="pe-err-title">
            Cette page est introuvable
        </h1>

        <p class="pe-err__desc">
            La page que vous cherchez a peut-être été déplacée, renommée ou n'existe plus.
            Vérifiez l'adresse ou revenez à l'accueil de
            <strong>{{ NAME_SITE }}</strong>.
        </p>

        <a href="{{ path('app_home') }}" class="pe-err__btn">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M19 12H5M12 5l-7 7 7 7"/>
            </svg>
            Retour à l'accueil
        </a>

        <a href="{{ path('app_catalogue') }}" class="pe-err__alt">
            Parcourir notre catalogue &rarr;
        </a>

    </div>
</main>
{% endblock %}
