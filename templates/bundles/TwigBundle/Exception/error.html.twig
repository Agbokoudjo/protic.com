{#
  templates/bundles/TwigBundle/Exception/error.html.twig
  ProTIC Editions & Services — Page d'erreur générique (500, 502, 503…)
  Couvre tous les codes HTTP non gérés par un fichier errorXXX.html.twig spécifique.
#}
{% extends 'base.html.twig' %}

{% block title %}
    {% if status_code == 503 %}Service indisponible
    {% elseif status_code == 403 %}Accès refusé
    {% else %}Erreur serveur{% endif %}
    ({{ status_code ?? 500 }}) — {{ NAME_SITE }}
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .pe-srv {
            min-height: calc(100vh - 124px);
            background: linear-gradient(155deg, #060e24 0%, #0d1f4e 40%, #0c1e52 70%, #101a42 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
            padding: 4rem 1.5rem;
        }
        .pe-srv__glow {
            position: absolute;
            width: 480px; height: 480px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(245,166,35,0.10) 0%, transparent 68%);
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            pointer-events: none; z-index: 0;
        }
        .pe-srv__dots {
            position: absolute;
            width: 110px; height: 110px;
            opacity: 0.12;
            background-image: radial-gradient(circle, rgba(255,255,255,0.55) 1px, transparent 1px);
            background-size: 14px 14px;
            pointer-events: none;
            top: 9%; right: 5%;
        }
        .pe-srv__dots--bl { top: auto; bottom: 11%; right: auto; left: 5%; }
        .pe-srv__inner {
            position: relative; z-index: 1;
            max-width: 620px; width: 100%;
            text-align: center;
        }
        .pe-srv__icon {
            display: inline-flex;
            align-items: center; justify-content: center;
            width: 78px; height: 78px;
            border-radius: 50%;
            background: rgba(245,166,35,0.09);
            border: 1px solid rgba(245,166,35,0.28);
            margin: 0 auto 1.5rem;
            backdrop-filter: blur(10px);
        }
        .pe-srv__icon svg { width: 36px; height: 36px; stroke: #f5a623; }
        .pe-srv__badge {
            display: inline-flex;
            align-items: center; gap: 6px;
            padding: 4px 14px; border-radius: 999px;
            background: rgba(245,166,35,0.10);
            border: 1px solid rgba(245,166,35,0.28);
            color: rgba(245,198,117,0.80);
            font-size: 0.72rem; font-weight: 600;
            letter-spacing: 0.08em; text-transform: uppercase;
            margin-bottom: 1.5rem;
        }
        .pe-srv__badge::before {
            content: ''; width: 6px; height: 6px;
            border-radius: 50%; background: #f5a623; display: inline-block;
        }
        .pe-srv__code {
            font-size: clamp(6rem, 20vw, 11rem);
            font-weight: 800; line-height: 1;
            letter-spacing: -0.04em;
            background: linear-gradient(135deg, #fce08a 0%, #f5a623 50%, #e07b10 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            user-select: none;
            filter: drop-shadow(0 0 36px rgba(245,166,35,0.32));
        }
        .pe-srv__divider {
            width: 56px; height: 3px;
            background: linear-gradient(90deg, #f5a623, rgba(245,166,35,0.30));
            border-radius: 3px;
            margin: 1rem auto 1.75rem;
        }
        .pe-srv__title {
            font-size: clamp(1.3rem, 4vw, 1.85rem);
            font-weight: 700; color: #ffffff;
            margin-bottom: 1rem; line-height: 1.25;
        }
        .pe-srv__desc {
            font-size: 1.05rem;
            color: rgba(255,255,255,0.68);
            line-height: 1.7; margin-bottom: 2.5rem;
            max-width: 460px;
            margin-left: auto; margin-right: auto;
        }
        .pe-srv__desc strong { color: rgba(255,255,255,0.90); font-weight: 600; }
        .pe-srv__detail {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.14);
            border-radius: 10px;
            padding: 0.9rem 1.1rem;
            margin-bottom: 2rem;
            text-align: left;
            backdrop-filter: blur(8px);
        }
        .pe-srv__detail-label {
            font-size: 0.7rem;
            color: rgba(255,255,255,0.38);
            letter-spacing: 0.07em;
            text-transform: uppercase;
            font-weight: 600;
            margin: 0 0 5px;
        }
        .pe-srv__detail code {
            font-size: 0.82rem;
            color: rgba(255,255,255,0.65);
            font-family: 'Courier New', monospace;
            word-break: break-all;
        }
        .pe-srv__btn {
            display: inline-flex;
            align-items: center; gap: 10px;
            padding: 13px 30px; border-radius: 10px;
            background: linear-gradient(135deg, #2d5be3 0%, #1a3a8f 100%);
            color: #ffffff;
            font-size: 0.92rem; font-weight: 600;
            text-decoration: none; letter-spacing: 0.02em;
            transition: transform 0.22s ease, box-shadow 0.22s ease;
            box-shadow: 0 4px 22px rgba(45,91,227,0.35);
        }
        .pe-srv__btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 32px rgba(45,91,227,0.52);
            color: #ffffff;
        }
        .pe-srv__btn:active { transform: translateY(0); }
        .pe-srv__btn svg {
            width: 17px; height: 17px; stroke: currentColor;
            transition: transform 0.20s ease; flex-shrink: 0;
        }
        .pe-srv__btn:hover svg { transform: translateX(-3px); }
        .pe-srv__alts {
            display: flex;
            align-items: center; justify-content: center;
            gap: 1.5rem; flex-wrap: wrap;
            margin-top: 1.4rem;
        }
        .pe-srv__alt {
            font-size: 0.85rem;
            color: rgba(255,255,255,0.38);
            text-decoration: none;
            transition: color 0.2s;
            display: inline-flex; align-items: center; gap: 5px;
        }
        .pe-srv__alt:hover { color: rgba(255,255,255,0.68); }
        .pe-srv__alt svg { width: 14px; height: 14px; stroke: currentColor; }
        .pe-srv__sep {
            color: rgba(255,255,255,0.18);
            font-size: 0.7rem;
            user-select: none;
        }
        @keyframes srvUp {
            from { opacity: 0; transform: translateY(18px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .pe-srv__inner > * { animation: srvUp 0.55s ease both; }
        .pe-srv__inner > *:nth-child(1) { animation-delay: 0.05s; }
        .pe-srv__inner > *:nth-child(2) { animation-delay: 0.12s; }
        .pe-srv__inner > *:nth-child(3) { animation-delay: 0.19s; }
        .pe-srv__inner > *:nth-child(4) { animation-delay: 0.25s; }
        .pe-srv__inner > *:nth-child(5) { animation-delay: 0.31s; }
        .pe-srv__inner > *:nth-child(6) { animation-delay: 0.37s; }
        .pe-srv__inner > *:nth-child(7) { animation-delay: 0.43s; }
        .pe-srv__inner > *:nth-child(8) { animation-delay: 0.49s; }
        @media (max-width: 480px) {
            .pe-srv { padding: 3rem 1rem; }
            .pe-srv__btn { width: 100%; justify-content: center; }
            .pe-srv__alts { flex-direction: column; gap: 0.75rem; }
            .pe-srv__sep { display: none; }
        }
    </style>
{% endblock %}
{% block header %}{% endblock %}
 {% block nav %}{% endblock %}
 {% block script_aos %} {% endblock %}
{% block body %}
<main class="pe-srv" role="main" aria-labelledby="pe-srv-title">

    <div class="pe-srv__glow" aria-hidden="true"></div>
    <div class="pe-srv__dots" aria-hidden="true"></div>
    <div class="pe-srv__dots pe-srv__dots--bl" aria-hidden="true"></div>

    <div class="pe-srv__inner">

        {# Icône alerte #}
        <div class="pe-srv__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5"
                 stroke-linecap="round" stroke-linejoin="round">
                {% if status_code == 503 %}
                    {# Icône horloge / maintenance #}
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12 6 12 12 16 14"/>
                {% elseif status_code == 403 %}
                    {# Icône verrou #}
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                {% else %}
                    {# Icône alerte générique #}
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="12" y1="8" x2="12" y2="12"/>
                    <line x1="12" y1="16" x2="12.01" y2="16"/>
                {% endif %}
            </svg>
        </div>

        {# Badge #}
        <p class="pe-srv__badge">Erreur {{ status_code ?? 500 }}</p>

        {# Grand numéro — dynamique #}
        <div class="pe-srv__code" aria-hidden="true">{{ status_code ?? 500 }}</div>

        <div class="pe-srv__divider"></div>

        {# Titre contextualisé selon le code HTTP #}
        <h1 class="pe-srv__title" id="pe-srv-title">
            {% if status_code == 503 %}
                Service temporairement indisponible
            {% elseif status_code == 502 %}
                Erreur de passerelle
            {% elseif status_code == 403 %}
                Accès refusé
            {% elseif status_code == 401 %}
                Authentification requise
            {% else %}
                Une erreur inattendue est survenue
            {% endif %}
        </h1>

        {# Description contextualisée #}
        <p class="pe-srv__desc">
            {% if status_code == 503 %}
                Notre plateforme est momentanément en maintenance.
                Notre équipe travaille activement au rétablissement du service.
                Merci de votre patience.
            {% elseif status_code == 502 %}
                Un problème de communication s'est produit avec nos serveurs.
                Veuillez patienter quelques instants et réessayer.
            {% elseif status_code == 403 %}
                Vous n'êtes pas autorisé à accéder à cette ressource de
                <strong>{{ NAME_SITE }}</strong>.
                Si vous pensez qu'il s'agit d'une erreur, contactez notre support.
            {% elseif status_code == 401 %}
                Vous devez être connecté pour accéder à cette page.
                Veuillez vous identifier et réessayer.
            {% else %}
                Une erreur inattendue s'est produite sur
                <strong>{{ NAME_SITE }}</strong>.
                Notre équipe technique a été automatiquement notifiée.
                Vous pouvez réessayer ou retourner à l'accueil.
            {% endif %}
        </p>

        {#
            Bloc de détail technique — uniquement visible en mode dev (app.debug).
            En production : Symfony ne transmet aucune information sensible.
        #}
        {% if app.debug and exception is defined %}
        <div class="pe-srv__detail" role="note" aria-label="Détail technique (dev)">
            <p class="pe-srv__detail-label">Message (environnement dev uniquement)</p>
            <code>{{ exception.message }}</code>
        </div>
        {% endif %}

        {# Bouton principal → accueil #}
        <a href="{{ path('app_home') }}" class="pe-srv__btn">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M19 12H5M12 5l-7 7 7 7"/>
            </svg>
            Retour à l'accueil
        </a>

        {# Liens secondaires #}
        <div class="pe-srv__alts">
            <a href="#" onclick="history.go(-1); return false;" class="pe-srv__alt">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="15 18 9 12 15 6"/>
                </svg>
                Page précédente
            </a>
            <span class="pe-srv__sep" aria-hidden="true">•</span>
            <a href="mailto:direction@proticeditions.com" class="pe-srv__alt">
                <svg viewBox="0 0 24 24" fill="none" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                    <polyline points="22,6 12,13 2,6"/>
                </svg>
                Contacter le support
            </a>
        </div>

    </div>
</main>
{% endblock %}
{% block footer %}{% endblock %}
