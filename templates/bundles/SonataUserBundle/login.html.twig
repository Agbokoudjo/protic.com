{% extends base_template %}
{% block sonata_nav %}{% endblock sonata_nav %}

{% block favicon %}
    <link rel="icon" href="{{ asset('assets/' ~ sonata_config.logo,'admin') }}" width="100" height="100">
{% endblock %}

{% block sonata_left_side %}{% endblock %}
 {% block sonata_header %}{% endblock %}
{% block body_attributes %}
    class="sonata-bc login-page {% if _use_icheck %}sonata-icheck{% endif %}"{% endblock %}
{% block stylesheets %} 

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap" rel="stylesheet"> 
{{ vite_entry_link_tags('login',[],'admin') }} {% endblock %}
{% block sonata_footer %} {% endblock %}

 {% block title %}Connexion — ProTIC Editions & Services{% endblock %}
{% block javascripts_inline %}{% endblock %}

{% block javascripts %}  
    {{ vite_entry_script_tags('login',[],'admin') }} 
    {{ vite_entry_script_tags('form',[],'app') }} 
{% endblock %}

{% block sonata_wrapper %}
   <div class="login-page">

    {# ── Background image ── #}
    <div class="login-bg" style="background-image: url({{asset('assets/images/login_bg.png','admin')}});">
        <div class="login-overlay"></div>
    </div>

    {# ── Formulaire de connexion ── #}
    <div class="login-wrapper">

        {# Card formulaire #}
        <div class="login-card">

            {# Logo + titre #}
            <div class="login-header">
                <img src="{{ asset('assets/images/logo.jpeg' ,'admin') }}"
                     alt="ProTIC Editions & Services"
                     class="login-logo">
                <h1 class="login-title">Espace Administration</h1>
                <p class="login-subtitle">ProTIC Editions & Services</p>
                <div class="login-divider"></div>
            </div>

            {# Messages d'erreur #}
            {% if error %}
                <div class="login-alert">
                    <span class="login-alert-icon">⚠️</span>
                    <span>{{ error.messageKey | trans(error.messageData, 'security') }}</span>
                </div>
            {% endif %}

            {# Formulaire #}
            <form method="post"
                  action="{{ path("app_admin_user_login") }}" 
                  role="form" 
                  name="login_form" 
                  class="login-form form-validate" 
                  data-turbo="false"
                  autocomplete="off">

                <div class="login-field">
                    <label for="username" class="login-label">
                        {{ ux_icon('fa:user') }}
                        Identifiant
                    </label>
                    <input type="email"
                           value="{{ last_username }}"
                           class="login-input"
                           autocomplete="username"
                           required
                           id="email"
                           name="email"
                           placeholder="Ex: admin@protic.com"
                            data-type="email"
                            data-allow-quoted-local="false"
                            maxlength="200"
                            minlength="6"
                            data-host-blacklist="tempmail.com,tempmail.org,tempmail.net,guerrillamail.com,guerrillamail.net,guerrillamail.org,guerrillamail.biz,guerrillamail.de,guerrillamail.info,mailinator.com,mailinator.net,mailinator.org,yopmail.com,yopmail.fr,yopmail.net,trashmail.com,trashmail.at,trashmail.me,trashmail.net,trashmail.org,trashmail.io,sharklasers.com,guerrillamailblock.com,grr.la,spam4.me,dispostable.com,10minutemail.com,10minutemail.net,10minutemail.org,10minutemail.co.uk,10minutemail.de,10minemail.com,throwam.com,throwaway.email,fakeinbox.com,fake-box.com,maildrop.cc,spamgourmet.com,spamgourmet.net,spamgourmet.org,mailnull.com,spamcowboy.com,spamcowboy.net,spamcowboy.org,spamevader.com,getairmail.com,discard.email,spamfree24.org,spamfree24.de,spamfree24.eu,spamfree24.info,spamfree24.net,mailnew.com,spamex.com,binkmail.com,bobmail.info,chammy.info,devnullmail.com,fudgerub.com,jobbikmail.com,yuurok.com,discardmail.com,discardmail.de,spamspot.com,spamthisplease.com,tempinbox.com,tempr.email,spam.la,inoutmail.de,inoutmail.eu,inoutmail.info,inoutmail.net,filzmail.com,weg-werf-email.de,wegwerfmail.de,wegwerfmail.net,wegwerfmail.org,meltmail.com,anonymbox.com,courriel.fr.nf,cool.fr.nf,jetable.fr.nf,nospam.ze.tc,nomail.xl.cx,mega.zik.dj,speed.1s.fr,iwi.net,jetable.net,jetable.org"
                            data-host-whitelist="gmail.com,protic.com,proticeditions.com"
                            data-event-validate-blur="blur"
                            data-event-validate-input="input"
                           autofocus>
                </div>

                <div class="login-field">
                    <label for="password" class="login-label">
                        {{ ux_icon('fa:lock') }}
                        Mot de passe
                    </label>
                    <div class="login-input-wrapper">
                        <input type="password"
                               id="password"
                               name="password"
                               class="login-input"
                               placeholder="Votre mot de passe"
                               autocomplete="current-password"
                                maxlength="255"
                                minlength="8"
                                data-event-validate-blur="blur"
                                data-event-validate-input="input"
                                data-enable-scoring="false"
                                data-custom-upper-regex="[\p{Lu}]"
                                data-custom-lower-regex="[\p{Ll}]"
                                data-custom-number-regex="[\p{N}]"
                                data-custom-symbol-regex="[\p{S}\p{P}]"
                                data-custom-special-char-regex="[\p{S}\p{P}\s]"
                                data-custom-punctuation-regex="[\p{P}]"
                                data-pattern="^[\p{L}\p{N}\p{M}\p{S}\p{P}\s]+$"
                               required>
                        <button type="button"
                                class="login-toggle-pw"
                                id="togglePassword"
                                title="Afficher/Masquer">
                            {# <i class="fas fa-eye" id="eyeIcon"></i> #}
                            {{ ux_icon('fa:eye',{id:'eyeIcon'}) }}
                        </button>
                    </div>
                </div>

                <div class="login-remember">
                    <label class="login-checkbox-label">
                        <input type="checkbox"
                               name="_remember_me"
                               id="remember_me"
                               class="login-checkbox">
                        <span class="login-checkbox-custom"></span>
                        <span>Se souvenir de moi</span>
                    </label>
                </div>
                 <input type="hidden" name="_csrf_token" value="{{ csrf_token }}"/>
                <button type="submit" class="login-btn">
                    <span class="login-btn-text">Se connecter</span>
                    {# <i class="fas fa-arrow-right login-btn-icon"></i> #}
                     {{ ux_icon('fa:arrow-right',{class:'login-btn-icon'}) }}
                </button>

            </form>

            {# Footer card #}
            <div class="login-card-footer">
                <span class="login-member-badge">
                    <i class="fas fa-shield-alt"></i>
                    Accès réservé aux administrateurs
                </span>
            </div>

        </div>

        {# Footer page #}
        <div class="login-page-footer">
            <span>© {{ "now" | date("Y") }} ProTIC Editions & Services</span>
            <span class="login-footer-dot">•</span>
            <span>Membre de l'APPEL-Bénin</span>
            <span class="login-footer-dot">•</span>
            <span>Abomey-Calavi, Bénin</span>
        </div>

    </div>
</div>
{% endblock sonata_wrapper %}

