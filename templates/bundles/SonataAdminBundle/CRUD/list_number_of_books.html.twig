 {% extends get_admin_template('base_list_field', admin.code) %}

{% block field %}
    {% if value > 0 %}
        <span class="badge" style="background-color: #FFD700; color: #0f1c3a; font-weight: 700; padding: 5px 10px; border-radius: 12px;">
            <i class="fas fa-book-open" style="margin-right: 4px;"></i>
            {{ value }}
        </span>
    {% else %}
        <span class="badge" style="background-color: rgba(255,255,255,0.1); color: rgba(255,255,255,0.4); border: 1px solid rgba(255,255,255,0.1);">
            0
        </span>
    {% endif %}
{% endblock %}