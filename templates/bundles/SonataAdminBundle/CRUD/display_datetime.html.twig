{%- apply trim|raw %}
    {%- if value is empty -%}
        &nbsp;
    {%- else -%}
         {% set datetime_value = value|date('c','UTC') %}
        <time 
            datetime="{{ datetime_value }}" 
            title="{{ datetime_value  }}"
             {{ stimulus_controller('date',{'date':datetime_value,'locale':app.locale}) }} 
        ></time>
    {%- endif -%}
{% endapply -%}
