  {% extends get_admin_template('base_list_field', admin.code) %}

{% block field %}
    {% set count = value %}
    
    <div class="text-center">
        {% if count > 0 %}
            <span class="badge" style="background-color: #FFD700; color: #0f1c3a; font-weight: 700; padding: 6px 12px; border-radius: 50px; box-shadow: 0 2px 5px rgba(0,0,0,0.3); display: inline-flex; align-items: center; gap: 6px;">
                <i class="fas fa-pen-nib"></i>
                {{ count }} {{ count > 1 ? 'livres publiés' : 'livre publié' }}
            </span>
        {% else %}
            <span class="badge" style="background-color: rgba(255,255,255,0.05); color: rgba(255,255,255,0.3); border: 1px solid rgba(255,255,255,0.1); border-radius: 50px; padding: 5px 10px;">
                <i class="fas fa-times-circle" style="font-size: 0.8em;"></i> Aucun livre
            </span>
        {% endif %}
    </div>
{% endblock %}