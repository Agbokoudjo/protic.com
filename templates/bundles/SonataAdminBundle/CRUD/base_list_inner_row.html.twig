{% for field_description in admin.list.getElements() %}
    {# Dans Sonata 5.x, si NAME_ACTIONS doit être masqué en AJAX,
       il aura déjà l'option 'ajax_hidden' à true via configureListFields. #}
    {% if field_description.getOption('ajax_hidden') == true and app.request.isXmlHttpRequest %}
        {# Le champ est masqué en AJAX si l'option 'ajax_hidden' est activée #}
    {% else %}
        {{ object|render_list_element(field_description) }}
    {% endif %}
{% endfor %}

