{#
  Composant : aperçu PDF manuscrit
  Usage dans show.html.twig ou un template custom de champ Sonata :

  {{ include('@App/Admin/components/pdf_preview.html.twig', {
      filename: object.manuscriptFilename,
      author:   object.fullName,
      subject:  object.subject,
      date:     object.submittedAt|date('d/m/Y'),
  }) }}
#}

{% set filename = filename ?? 'manuscript.pdf' %}
{% set author   = author   ?? 'Auteur inconnu' %}
{% set subject  = subject  ?? 'Manuscrit sans titre' %}
{% set date     = date     ?? 'Date inconnue' %}

<div class="pdf-preview-card" style="
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    width: 180px;
    cursor: pointer;
    font-family: inherit;
">
    {# ── Corps du PDF simulé ────────────────────────── #}
    <div class="pdf-body" style="
        width: 140px;
        height: 190px;
        background: #ffffff;
        border: 1px solid #d0cec8;
        border-radius: 3px 12px 3px 3px;
        position: relative;
        box-shadow: 2px 3px 8px rgba(0,0,0,0.18), 4px 6px 16px rgba(0,0,0,0.10);
        overflow: hidden;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    "
    onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='3px 6px 18px rgba(0,0,0,0.25)';"
    onmouseout="this.style.transform='';this.style.boxShadow='2px 3px 8px rgba(0,0,0,0.18), 4px 6px 16px rgba(0,0,0,0.10)';"
    >
        {# Coin replié (oreille) #}
        <div style="
            position: absolute;
            top: 0; right: 0;
            width: 0; height: 0;
            border-style: solid;
            border-width: 0 28px 28px 0;
            border-color: transparent #e5e2da transparent transparent;
            z-index: 2;
        "></div>
        <div style="
            position: absolute;
            top: 0; right: 0;
            width: 28px; height: 28px;
            background: #f5f2ed;
            clip-path: polygon(100% 0, 100% 100%, 0 0);
            border-left: 1px solid #d0cec8;
            border-bottom: 1px solid #d0cec8;
            z-index: 3;
        "></div>

        {# Bande rouge PDF en haut #}
        <div style="
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 36px;
            background: linear-gradient(135deg, #c0392b, #e74c3c);
            display: flex;
            align-items: center;
            padding: 0 10px;
            gap: 6px;
        ">
            <span style="
                color: white;
                font-size: 11px;
                font-weight: 700;
                letter-spacing: 1px;
                text-transform: uppercase;
            ">PDF</span>
            <div style="flex:1; height:1px; background:rgba(255,255,255,0.3);"></div>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
                <polyline points="10 9 9 9 8 9"/>
            </svg>
        </div>

        {# Lignes simulant le texte du manuscrit #}
        <div style="padding: 46px 10px 10px;">
            {# Titre simulé #}
            <div style="height:5px; background:#2c3e50; border-radius:2px; margin-bottom:8px; width:85%;"></div>
            <div style="height:4px; background:#2c3e50; border-radius:2px; margin-bottom:12px; width:60%;"></div>
            {# Paragraphes simulés #}
            {% for i in 1..8 %}
                <div style="
                    height: 3px;
                    background: #bbb;
                    border-radius: 2px;
                    margin-bottom: 5px;
                    width: {{ [100, 95, 88, 92, 85, 97, 80, 90][i - 1] }}%;
                "></div>
            {% endfor %}
            {# Séparateur #}
            <div style="height:1px; background:#eee; margin: 10px 0;"></div>
            {% for i in 1..4 %}
                <div style="
                    height: 3px;
                    background: #ccc;
                    border-radius: 2px;
                    margin-bottom: 5px;
                    width: {{ [90, 75, 85, 65][i - 1] }}%;
                "></div>
            {% endfor %}
        </div>

        {# Badge page en bas à droite #}
        <div style="
            position: absolute;
            bottom: 6px; right: 8px;
            font-size: 8px;
            color: #aaa;
            font-style: italic;
        ">p. 1</div>
    </div>

    {# ── Métadonnées sous le PDF ─────────────────────── #}
    <div style="
        margin-top: 10px;
        text-align: center;
        max-width: 160px;
    ">
        <div style="
            font-size: 11px;
            font-weight: 600;
            color: rgba(255,255,255,0.85);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 155px;
        " title="{{ filename }}">{{ filename }}</div>
        <div style="font-size: 10px; color: rgba(255,255,255,0.45); margin-top: 3px;">{{ author }}</div>
        <div style="font-size: 10px; color: rgba(255,215,0,0.60); margin-top: 2px;">{{ date }}</div>
    </div>

    {# ── Bouton télécharger ──────────────────────────── #}
    {% if filename %}
    <a href="{{ asset('uploads/manuscripts/' ~ filename) }}"
       target="_blank"
       download
       style="
           margin-top: 10px;
           display: inline-flex;
           align-items: center;
           gap: 5px;
           background: rgba(231,76,60,0.15);
           border: 1px solid rgba(231,76,60,0.35);
           color: #e74c3c;
           font-size: 11px;
           font-weight: 600;
           padding: 5px 12px;
           border-radius: 20px;
           text-decoration: none;
           transition: all 0.2s ease;
       "
       onmouseover="this.style.background='rgba(231,76,60,0.28)';this.style.borderColor='rgba(231,76,60,0.6)';"
       onmouseout="this.style.background='rgba(231,76,60,0.15)';this.style.borderColor='rgba(231,76,60,0.35)';"
    >
        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Voir le PDF
    </a>
    {% endif %}
</div>
