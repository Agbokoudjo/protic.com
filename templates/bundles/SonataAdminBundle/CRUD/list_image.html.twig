{% extends get_admin_template('base_list_field', admin.code) %}

{% import 'bundles/SonataAdminBundle/CRUD/Macros/image.html.twig' as image_render  %}
{% block field %}
     {% set  date_object = object.updatedAt|date('Y-m-d H-i-s')  %}
     {% set  idobject = object.id ~ '-' ~ '-' ~ date_object ~ '-' ~ admin.code %}
     {% cache 'image-user-'~ idobject ttl(CACHE_IMG_TWIG) tags('image'~ idobject) %} 
        {% if field_description.type == 'Vich\\UploaderBundle\\Form\\Type\\VichImageType' %}
            {% set fieldimgname = field_description.fieldName %}
        {% endif %}
        {{image_render.renderImage(object,fieldimgname)}}
    {% endcache %} 
{% endblock %}