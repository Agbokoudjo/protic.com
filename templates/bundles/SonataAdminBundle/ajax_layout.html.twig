{% block content %}
    {% set _list_table = block('list_table') is defined ? block('list_table')|trim : null %}
    {% set _list_filters = block('list_filters') is defined ? block('list_filters')|trim : null %}
    {% set _list_filters_actions = block('list_filters_actions') is defined ? block('list_filters_actions')|trim : null %}
    {% set _actions = block('actions') is defined ? block('actions')|trim : null %}

    {% block preview %}{% endblock %}
    {% block form %}{% endblock %}
    {% block list %}{% endblock %}
    {% block show %}{% endblock %}
    {% block tab_menu_navbar_header %} {% endblock %} 

    {% if _list_table is not empty or _list_filters is not empty %}
    <div class="container-fluid">
        <div class="row">
            <div class="navbar navbar-default sonata-list-table">
                <div class="container-fluid">
                    <div class="navbar-collapse">
                        {% if admin is defined and action is defined and action == 'list' and admin.listModes|length > 1 %}
                            <div class="nav navbar-right-mode btn-group">
                                {% for mode, settings in admin.listModes %}
                                    <a href="{{ admin.generateUrl('list', app.request.query.all|merge({_list_mode: mode})) }}" class="btn btn-default navbar-btn btn-sm{% if admin.getListMode() == mode %} active{% endif %}">
                                        
                                            {{ settings.icon|default('')|parse_icon }}
                                    </a>
                                {% endfor %}
                            </div>
                        {% endif %}
                        {% if  _actions is not empty %}
                            <ul class="nav navbar-nav navbar-right container-sonata-actions" id="container-sonata-actions">
                                {% if _actions|split('</a>')|length > 2 %}
                                    <li class="dropdown sonata-actions">
                                        <a href="#" class="btn text-white border text-decoration-none dropdown-toggle

                                        {% if _show is not empty %}
                                                sonata-ba-show-actions-dropdown-toggle

                                            {% endif %}
                                    " 
                                        data-bs-toggle="dropdown">
                                        {{ 'link_actions'|trans({}, 'SonataAdminBundle') }} 
                                        <b class="caret"></b>
                                </a>
            
                                    <ul class="dropdown-menu
                                                dropdown-menu-end
                                            {% if _show is not empty %}
                                                    sonata-ba-show-actions-dropdown-menu 
                                                {% endif %}
                                            " 
                                        role="menu">
                                        {{ _actions|raw }}
                                    </ul>
                                </li>
                            {% else %}
                                <li class="single-action">
                                    {{_actions|replace({ '<li>': '', '</li>': '' })|trim|raw}}
                                </li>
                            {% endif %}
                        </ul>
                        {% endif %}
                        {% if _list_filters_actions is not empty %}
                            {{ _list_filters_actions|raw }}
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        {% if _list_filters|trim %}
            <div class="row">
                {{ _list_filters|raw }}
            </div>
        {% endif %}

        <div class="row">
            {{ _list_table|raw }}
        </div>
    </div>
    {% endif %}
{% endblock %}
