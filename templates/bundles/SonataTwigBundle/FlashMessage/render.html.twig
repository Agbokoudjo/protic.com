{% set collapse = collapse|default(1) %}

{% for type in sonata_flashmessages_types() %}
    {% set messages = sonata_flashmessages_get(type) %}
    {% if messages|length > collapse and collapse > 0 %}
        <div class="alert alert-{{ sonata_flashmessages_class(type, 'secondary') }} alert-dismissible fade show">
            <button
                type="button"
                class="btn-close"
                data-bs-dismiss="alert"
                aria-label="{{ 'message_close'|trans({}, 'SonataTwigBundle') }}">
            </button>

            <input type="checkbox" class="read-more-state d-none" id="toggle-more-{{ loop.index }}" />
            <div class="read-more-wrap" style="font-size:18px ;">
                {% for message in messages %}
                    {% if loop.index > collapse %}
                        <span class="read-more-target d-block">{{ message|raw }}</span>
                    {% else %}
                        {{ message|raw }}
                    {% endif %}
                {% endfor %}
            </div>

            <label for="toggle-more-{{ loop.index }}" class="read-more-trigger d-block mt-2">
                <span class="more text-primary small">{{ 'more'|trans({}, 'SonataTwigBundle') }} &#9660;</span>
                <span class="less text-primary small d-none">{{ 'less'|trans({}, 'SonataTwigBundle') }} &#9650;</span>
                <span class="badge bg-secondary ms-2">{{ messages|length }}</span>
            </label>
        </div>
    {% elseif messages|length > 0 %}
        {% for message in messages %}
            <div class="alert alert-{{ sonata_flashmessages_class(type, 'secondary') }} alert-dismissible fade show" style="font-size:18px ;">
                {% if app.request.isxmlhttprequest == false %}
                    <button
                    type="button"
                    class="btn-close"
                    data-bs-dismiss="alert"
                    aria-label="{{ 'message_close'|trans({}, 'SonataTwigBundle') }}">
                    </button>
                {% endif %}
                {{ message|raw }}
            </div>
        {% endfor %}
    {% endif %}
{% endfor %}
