                "@type": "Organization",
                "name": "ProTIC Editions & Services",
                "description": "Maison d'édition béninoise — publication, impression et distribution de livres",
                "url": "https://www.proticeditions.com",
                "logo": "{{ absolute_url(asset('assets/images/logo.png','app')) }}",
                "address": {
                    "@type": "PostalAddress",
                    "streetAddress": "Campus d'Abomey-Calavi, K61-62",
                    "addressLocality": "Abomey-Calavi",
                    "addressCountry": "BJ"
                },
                "telephone": ["+229 0195869951"],
                "email": "direction@proticeditions.com",
                "sameAs": [],
                "foundingDate": "2010",
                "creator": {
                    "@type": "Organization",
                    "name": "INTERNATIONALES WEB APPS & SERVICES",
                    "email": "internationaleswebservices@gmail.com",
                    "telephone": "+22901672518 86",
                    "sameAs": [
                        "https://github.com/Agbokoudjo/",
                        "https://www.linkedin.com/in/internationales-web-apps-services-120520193/"
                    ]
                }
            }
        </script>
    {% endblock %}
     {# Scripts Vite (React, app JS) #}
    {% block javascripts %}
        {{ vite_entry_script_tags('app') }}

    {% endblock %}
</head>
<body class="protic-body {{app.environment}}">
    {% block header %}
        {% include 'partials/_header.html.twig' %}
    {% endblock %}

    {% block nav %}
        {% include 'partials/_nav.html.twig' %}
    {% endblock %}

    <main id="main-content">
        {% block main %}{% endblock %}
    </main>

    {% block footer %}
        <twig:SiteSettings />
    {% endblock %}

    {# AOS — animations au scroll #}
    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script>
        function initAOS() {
        AOS.init({
            duration        : 700,
            easing          : 'ease-out-cubic',
            once            : false, 
            offset          : 80,
            anchorPlacement : 'top-bottom',
        });
    }
    
    document.addEventListener('DOMContentLoaded', () => {
        initAOS();
        window.AOS = AOS;
    });

    document.addEventListener('turbo:load', () => {
        const aosElements = document.querySelectorAll('.aos-animate');
        aosElements.forEach(el => el.classList.remove('aos-animate', 'aos-init'));
        
        initAOS(); 
        
        if (typeof jQuery !== 'undefined') {
            window.jQuery = window.$ = jQuery;
        }
    });
    </script>

    {# Three.js — injecté uniquement sur les pages qui en ont besoin #}
    {% block threejs %}{% endblock %}

    {% block scripts_extra %}{% endblock %}
</body>
</html>