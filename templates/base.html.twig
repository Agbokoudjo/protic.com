<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}ProTIC Editions & Services{% endblock %}</title>
    <meta name="description" content="{% block meta_description %}Maison d'édition béninoise engagée pour la promotion du livre et des auteurs.{% endblock %}">
    <meta name="iws-config" content="{{ {
                          DEBUG: app.debug ?? false,
                          APP_ENV: app.environment ?? 'prod',
                          LOCALE: app.locale ?? 'fr',
                          ENABLE_LOCALE: app.enabled_locales ?? []
                      }|json_encode()|e('html_attr') }}">
                      
    <link rel="icon" href="{{ asset('assets/images/logo.png','app') }}" width="75" height="75">

    {# ── AOS animations ── #}
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css">

    {# ── Bootstrap Icons ── #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    {# ── CSS global ProTIC ── #}
    {% block stylesheets %}
        {{ vite_entry_link_tags('app') }}
    {% endblock %}

    {% block head_extra %}
        <script type="application/ld+json">
            {
                "@context": "https://schema.org",
                "@type": "Organization",
                "name": "ProTIC Editions & Services",
                "description": "Maison d'édition béninoise — publication, impression et distribution de livres",
                "url": "https://www.proticeditions.com",
                "logo": "https://www.proticeditions.com/assets/images/logo.png",
                "address": {
                    "@type": "PostalAddress",
                    "streetAddress": "Campus d'Abomey-Calavi, K61-62",
                    "addressLocality": "Abomey-Calavi",
                    "addressCountry": "BJ"
                },
                "telephone": ["+22995869951"],
                "email": "proticeditions@gmail.com",
                "sameAs": [],
                "foundingDate": "2010"
            }
        </script>
    {% endblock %}
</head>
<body class="protic-body {{app.environment}}">
    {% block header %}
        {% include 'partials/_header.html.twig' %}
    {% endblock %}

    {% block nav %}
        {% include 'partials/_nav.html.twig' %}
    {% endblock %}

    <main id="main-content">
        {% block main %}{% endblock %}
    </main>

    {% block footer %}
        <twig:SiteSettings />
    {% endblock %}

    {# AOS — animations au scroll #}
    <script src="https://unpkg.com/aos@next/dist/aos.js"></script>
    <script>
        AOS.init({
            duration        : 700,
            easing          : 'ease-out-cubic',
            once            : true,
            offset          : 80,
            anchorPlacement : 'top-bottom',
        });
        window.AOS=AOS ;
    </script>

    {# Three.js — injecté uniquement sur les pages qui en ont besoin #}
    {% block threejs %}{% endblock %}

    {# Scripts Vite (React, app JS) #}
    {% block javascripts %}
        {{ vite_entry_script_tags('app') }}
    {% endblock %}

    {% block scripts_extra %}{% endblock %}
</body>
</html>